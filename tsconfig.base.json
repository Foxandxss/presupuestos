{
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@operaciones/dominio": ["libs/operaciones/dominio/index.ts"],
      "@operaciones/ui/charts": ["libs/operaciones/ui/charts/index.ts"],
      "@operaciones/ui/command-palette": [
        "libs/operaciones/ui/command-palette/index.ts"
      ],
      "@operaciones/ui/dialogos": ["libs/operaciones/ui/dialogos/index.ts"],
      "@operaciones/ui/errores": ["libs/operaciones/ui/errores/index.ts"],
      "@operaciones/ui/estados-pedido": [
        "libs/operaciones/ui/estados-pedido/index.ts"
      ],
      "@operaciones/ui/iconos": ["libs/operaciones/ui/iconos/index.ts"],
      "@operaciones/ui/kpis": ["libs/operaciones/ui/kpis/index.ts"],
      "@operaciones/ui/listado": ["libs/operaciones/ui/listado/index.ts"],
      "@operaciones/ui/shell": ["libs/operaciones/ui/shell/index.ts"],
      "@operaciones/ui/tokens": ["libs/operaciones/ui/tokens/index.ts"]
    },
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "module": "esnext",
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "importHelpers": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": true,
    "useDefineForClassFields": false,
    "forceConsistentCasingInFileNames": true
  }
}
